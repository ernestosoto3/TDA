# ==================================================
# Dependencies and package managers
# ==================================================

node_modules/
.pnpm-store/
.pnpm-debug.log*

npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*


# ==================================================
# Environment variables and secrets
# ==================================================

.env
.env.*
!.env.example
!.env.*.example

# Local EAS signing credentials
credentials.json

# Firebase service accounts
service-account*.json
*-firebase-adminsdk-*.json

# Certificates, signing keys, and provisioning files
*.jks
*.keystore
*.p8
*.p12
*.pem
*.key
*.mobileprovision

# Firebase native configuration
# Keep these ignored when supplying them through EAS file variables.
**/google-services.json
**/GoogleService-Info.plist


# ==================================================
# Expo and React Native
# ==================================================

.expo/
.expo-shared/
expo-env.d.ts
.metro-health-check*
web-build/
.kotlin/
*.orig.*

# Expo generated native projects
# Appropriate when using Expo Prebuild/CNG and not manually maintaining
# the native Android and iOS projects.
apps/*/android/
apps/*/ios/


