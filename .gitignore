# ==================================================

dist/
build/
out/

.turbo/
.cache/
.parcel-cache/

*.tsbuildinfo

.eslintcache
.stylelintcache

coverage/
.nyc_output/
*.lcov

logs/
*.log

report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json


# ==================================================
# Local Redis data
# ==================================================

dump.rdb
appendonly.aof
appendonlydir/


